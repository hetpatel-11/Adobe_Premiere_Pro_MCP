{
  "id": "com.mcp.premiere.uxpbridge",
  "name": "MCP Bridge (UXP)",
  "version": "2.0.0",
  "manifestVersion": 6,
  "main": "main.js",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "24.4.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "mcp-uxp-bridge-panel",
      "label": { "default": "MCP Bridge (UXP)" },
      "preferredDockedSize": { "width": 400, "height": 600 },
      "icons": [],
      "file": "panel.html"
    }
  ],
  "requiredPermissions": {
    "allowCodeGenerationFromStrings": true,
    "network": {
      "domains": ["localhost", "127.0.0.1", "api.giphy.com", "fal.run", "*.fal.ai", "pixabay.com"]
    },
    "localFileSystem": "fullAccess"
  }
}
